{
  "compilerOptions": {
    // Среда выполнения — Node 22. Фиксируем es2024 вместо плавающего esnext.
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "es2024",
    "lib": ["es2024"],
    "types": ["node"],

    // Конфиг только проверяет типы (tsc --noEmit). Сборку в dist делает swc.
    "noEmit": true,
    "sourceMap": true,
    "incremental": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,

    // Декораторы NestJS (DI работает через reflect-metadata)
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    // Строгая типизация
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  },
  "include": ["src/**/*", "test/**/*", "features/**/*", "prisma/**/*"],
  "exclude": ["node_modules", "dist"]
}
